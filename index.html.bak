  const STARTING_ITEMS = [
    { id: 'rust_blade',     name: 'Rust-Stained Blade',    type: 'weapon',     rarity: 'common',    icon: '&#x2694;',  stats: { atk: 8 },  desc: 'A blade that has seen too much blood. Yours included.' },
    { id: 'patch_coat',     name: 'Patchwork Greatcoat',   type: 'armor',      rarity: 'common',    icon: '&#x1F9E5;', stats: { def: 5 },  desc: 'Mended more times than your spirit.' },
    { id: 'essence_vial',   name: 'Essence Vial',          type: 'consumable', rarity: 'uncommon',  icon: '&#x2697;',  desc: 'Distilled emotion. Restores 50 MP.', effect: { mp: 50 } },
    { id: 'medkit',         name: 'Scavenged Medkit',      type: 'consumable', rarity: 'common',    icon: '&#x1FA79;', stats: {},         desc: 'Sterility not guaranteed. Restores 40 HP.', effect: { hp: 40 } },
    { id: 'choir_mask',     name: 'Choir Mask Fragment',   type: 'key',        rarity: 'rare',      icon: '&#x1F3AD;', stats: {},         desc: 'A piece of the Hollow Choir\'s collective identity.' },
    { id: 'debt_ledger',    name: 'Debt Ledger',           type: 'key',        rarity: 'uncommon',  icon: '&#x1F4D6;', stats: {},         desc: 'Names of those you collected from. Some are crossed out.' },
    { id: 'neon_shard',     name: 'Neon Shard',            type: 'consumable', rarity: 'uncommon',  icon: '&#x2728;',  desc: 'Glows with trapped light. Restores 30 HP.', effect: { hp: 30 } },
    { id: 'scavenger_brew', name: 'Scavenger\'s Brew',     type: 'consumable', rarity: 'common',    icon: '&#x1F37A;', desc: 'Questionable fermentation. Restores 25 HP.', effect: { hp: 25 } }
  ];

  // ═══════════════════════════════════════════════════════════════
  // INITIALIZATION
  // ═══════════════════════════════════════════════════════════════
  function init() {
    generateParticles();
    initInventory();
    initMiniMap();
    checkSaves();
    // Set default archetype if none selected
    if (!state.archetype) {
      selectArchetype('protagonist');
    }
    updatePreview();
    console.log('[CoS Engine v2.0] Covenant of Shadows initialized. All systems online.');
  }

  function generateParticles() {
    const container = document.getElementById('particles');
    if (!container) return;
    container.innerHTML = '';
    for (let i = 0; i < 50; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.left = Math.random() * 100 + '%';
      p.style.animationDelay = Math.random() * 10 + 's';
      p.style.animationDuration = (6 + Math.random() * 8) + 's';
      const size = 1 + Math.random() * 3;
      p.style.width = size + 'px';
      p.style.height = size + 'px';
      p.style.opacity = 0.3 + Math.random() * 0.5;
      container.appendChild(p);
    }
  }

  function initInventory() {
    state.inventory = STARTING_ITEMS.map(item => ({...item, equipped: false, count: 1 }));
    state.equipped.weapon = state.inventory[0];
    state.equipped.armor = state.inventory[1];
    state.inventory[0].equipped = true;
    state.inventory[1].equipped = true;
  }

  function initMiniMap() {
    const map = document.getElementById('miniMap');
    if (!map) return;
    map.innerHTML = '';
    ROOMS.forEach((room, i) => {
      const node = document.createElement('div');
      node.className = 'map-node' + (i === 0 ? ' current' : '') + (i === ROOMS.length - 1 ? ' boss' : '');
      node.title = room.title;
      map.appendChild(node);
    });
  }

  function checkSaves() {
    const continueBtn = document.getElementById('continueBtn');
    if (!continueBtn) return;
    let hasSave = false;
    for (let i = 1; i <= 3; i++) {
      if (localStorage.getItem('cos_save_' + i)) { hasSave = true; break; }
    }
    continueBtn.disabled = !hasSave;
  }

  // ═══════════════════════════════════════════════════════════════
  // SCENE MANAGEMENT
  // ═══════════════════════════════════════════════════════════════
  function showScene(sceneId) {
    document.querySelectorAll('.scene').forEach(s => {
      s.classList.remove('active');
      if (s.id !== 'scene-title') s.style.display = 'none';
    });
    const target = document.getElementById('scene-' + sceneId);
    if (target) {
      target.style.display = '';
      target.style.opacity = '0';
      requestAnimationFrame(() => {
        target.classList.add('active');
        target.style.opacity = '1';
      });
    }
    state.prevScene = state.scene;
    state.scene = sceneId;

    // Auto-save on scene transition
    if (state.settings.autoSave && sceneId === 'game') {
      autoSave();
    }
  }

  function returnToGame() {
    showScene('game');
    document.getElementById('scene-game').style.display = 'block';
  }

  function returnToTitle() {
    document.querySelectorAll('.scene').forEach(s => {
      s.classList.remove('active');
      if (s.id !== 'scene-title') s.style.display = 'none';
    });
    const title = document.getElementById('scene-title');
    title.style.display = 'flex';
    title.classList.remove('hidden');
    title.style.opacity = '1';
    state.scene = 'title';
    checkSaves();
  }

  function resetToTitle() {
    returnToTitle();
  }

  function toCreation() {
    document.getElementById('scene-title').classList.add('hidden');
    setTimeout(() => {
      document.getElementById('scene-title').style.display = 'none';
      showScene('creation');
    }, 1500);
  }

  function toSettings() {
    showScene('settings');
    renderSaveSlots();
  }

  function toSocial() {
    showScene('social');
    renderSocialLinks();
  }

  function toSkillTree() {
    showScene('skilltree');
    renderSkillTree();
  }

  function toInventory() {
    showScene('inventory');
    renderInventory();
  }

  function openMenu() {
    toSettings();
  }

  function showCredits() {
    showScene('credits');
  }

  function resetToTitle() {
    returnToTitle();
  }

  // ═══════════════════════════════════════════════════════════════
  // CHARACTER CREATION
  // ═══════════════════════════════════════════════════════════════
  function selectAsset(type, value) {
    state.assets[type] = value;
    document.querySelectorAll(`[data-asset="${type}"]`).forEach(el => {
      el.classList.toggle('selected', el.dataset.value === value);
    });
    updatePreview();
  }

  function selectColor(color) {
    state.color = color;
    document.querySelectorAll('.color-option').forEach(el => {
      el.classList.toggle('selected', el.dataset.color === color);
    });
    updatePreview();
  }

  function setRotation(rot) {
    state.rotation = rot;
    document.querySelectorAll('.rotation-btn').forEach(btn => {
      btn.classList.remove('active');
    });
    const activeBtn = document.getElementById('rot-' + rot);
    if (activeBtn) activeBtn.classList.add('active');

    // Swap the preview image to the correct sprite view
    const img = document.getElementById('charPreviewImg');
    if (img && state.archetype && SPRITES[state.archetype]) {
      img.src = SPRITES[state.archetype][rot] || SPRITES[state.archetype].front;
    }
  }


  function selectArchetype(archetype) {
    state.archetype = archetype;
    document.querySelectorAll('.archetype-card').forEach(c => {
      c.classList.toggle('selected', c.dataset.archetype === archetype);
    });

    // Update preview image to front view of selected archetype
    const img = document.getElementById('charPreviewImg');
    if (img && SPRITES[archetype]) {
      img.src = SPRITES[archetype][state.rotation] || SPRITES[archetype].front;
    }

    // Update preview panel title
    const title = document.getElementById('previewPanelTitle');
    if (title) title.innerHTML = '&#x25CE; ' + (ARCHETYPE_NAMES[archetype] || 'The Penitent');

    // Update echo preview if one is selected
    if (state.echo) {
      const echoImg = document.getElementById('echoPreviewImg');
      if (echoImg) echoImg.src = ARCHETYPE_ECHO[archetype] || 'sprites/echo_protagonist.png';
    }
  }

  function selectOrigin(origin) {
    document.querySelectorAll('.origin-card').forEach(c => c.classList.remove('selected'));
    document.querySelector(`[data-origin="${origin}"]`).classList.add('selected');
    state.origin = origin;
    state.originName = ORIGINS[origin].name;
    recalcCorruption();
  }

  function selectEcho(echo) {
    document.querySelectorAll('.echo-card').forEach(c => c.classList.remove('selected'));
    document.querySelector(`[data-echo="${echo}"]`).classList.add('selected');
    state.echo = echo;
    state.echoName = ECHOES[echo].name;
    recalcCorruption();

    // Update echo preview image based on archetype
    const echoPanel = document.getElementById('echoPreviewPanel');
    const echoImg = document.getElementById('echoPreviewImg');
    if (echoPanel && echoImg) {
      // Use archetype-specific echo sprite if archetype selected, else fall back to ECHO_IMAGES
      if (state.archetype && ARCHETYPE_ECHO[state.archetype]) {
        echoImg.src = ARCHETYPE_ECHO[state.archetype];
      } else {
        echoImg.src = ECHO_IMAGES[echo] || 'sprites/echo_protagonist.png';
      }
      echoPanel.classList.add('active');
    }
  }

  function updateName(val) { state.name = val; }

  function adjustStat(stat, delta) {
    const newVal = state.stats[stat] + delta;
    if (newVal < 1 || newVal > 20) return;
    if (delta > 0 && state.points <= 0) return;
    if (delta < 0 && state.stats[stat] <= 1) return;
    state.stats[stat] = newVal;
    state.points -= delta;
    document.getElementById(`${stat}-val`).textContent = newVal;
    document.getElementById('pointsRemaining').textContent = state.points;
  }

  function updatePreview() {
    const img = document.getElementById('charPreviewImg');
    if (img) {
      img.style.borderColor = state.color;
      img.style.boxShadow = `0 0 15px ${state.color}60`;
      // Load the correct archetype sprite if archetype is selected
      if (state.archetype && SPRITES[state.archetype]) {
        img.src = SPRITES[state.archetype][state.rotation] || SPRITES[state.archetype].front;
      }
    }
  }

  function recalcCorruption() {
    let base = 0;
    if (state.origin) base += ORIGINS[state.origin].corruption;
    if (state.echo) base += ECHOES[state.echo].corruption;
    state.corruption = Math.min(100, base);
    const bar = document.getElementById('corruptionBar');
    const val = document.getElementById('corruptionValue');
    if (bar) bar.style.width = state.corruption + '%';
    if (val) val.textContent = state.corruption + '%';
  }

  function randomizeChar() {
    const origins = Object.keys(ORIGINS);
    const echoes = Object.keys(ECHOES);
    const archetypes = Object.keys(SPRITES);
    const colors = ['#FF0040','#00FFFF','#B8860B','#FF00FF','#008080','#8B0000'];

    selectArchetype(archetypes[Math.floor(Math.random()*archetypes.length)]);
    selectOrigin(origins[Math.floor(Math.random()*origins.length)]);
    selectEcho(echoes[Math.floor(Math.random()*echoes.length)]);
    selectColor(colors[Math.floor(Math.random()*colors.length)]);

    const names = ['Vesper','Cassius','Magdalene','Orin','Silas','Lilith','Gideon','Morrigan','Ash','Riven','Thorne','Echo'];
    document.getElementById('charName').value = names[Math.floor(Math.random()*names.length)];
    state.name = document.getElementById('charName').value;

    state.points = 15;
    Object.keys(state.stats).forEach(s => state.stats[s] = 5);
    while (state.points > 0) {
      const stat = Object.keys(state.stats)[Math.floor(Math.random()*5)];
      if (state.stats[stat] < 20) { state.stats[stat]++; state.points--; }
    }
    Object.keys(state.stats).forEach(s => {
      document.getElementById(`${s}-val`).textContent = state.stats[s];
    });
    document.getElementById('pointsRemaining').textContent = 0;
  }

  function startGame() {
    if (!state.archetype || !state.origin || !state.echo) {
      showNotification('Incomplete', 'Complete your Archetype, Origin and Echo selections before sealing the covenant.');
      return;
    }
    if (!state.name.trim()) {
      state.name = ARCHETYPE_NAMES[state.archetype] || 'The Penitent';
      document.getElementById('charName').value = state.name;
    }

    // Apply origin stats
    applyOriginStats();

    // Update HUD with archetype sprite
    const archetypeName = state.archetype;
    document.getElementById('partyName1').textContent = state.name;
    document.getElementById('partyRole1').textContent = state.originName.split(' ').pop();
    document.getElementById('protagonist-avatar').src = SPRITES[archetypeName].front;
    document.getElementById('playerCombatImg').src = SPRITES[archetypeName].front;
    document.getElementById('playerCombatName').textContent = state.name;
    // Store archetype for echo transform
    state.echoTransformSprite = ARCHETYPE_ECHO[archetypeName] || 'sprites/echo_protagonist.png';
    updateHPDisplay();
    updateCorruptionDisplay();
    updateSocialDisplay();

    // Transition to game
    document.getElementById('scene-creation').classList.remove('active');
    setTimeout(() => {
      document.getElementById('scene-creation').style.display = 'none';
      showScene('game');
      document.getElementById('scene-game').style.display = 'block';
      // Start first dialogue
      loadDialogue('opening_silas');
    }, 500);
  }

  function applyOriginStats() {
    const bonuses = {
      concordat:  { vit: 1, syn: 1, frc: 1, nex: 1, vel: 1 },
      hollow:     { vit: 0, syn: 1, frc: 0, nex: 2, vel: 2 },
      undercroft: { vit: 3, syn: 0, frc: 2, nex: 0, vel: 0 },
      echotouched:{ vit: 0, syn: 3, frc: 1, nex: 1, vel: 0 }
    };
    const b = bonuses[state.origin] || bonuses.concordat;
    Object.keys(b).forEach(s => { state.stats[s] += b[s]; });
  }

  // ═══════════════════════════════════════════════════════════════
  // DIALOGUE SYSTEM — Typewriter, Choices, Morality Tags
  // ═══════════════════════════════════════════════════════════════

  /**
   * Dialogue data structure:
   * Each dialogue has: speaker, speakerId (for image), text,
   * choices[] with { text, tag, tagText, effect, next?, requiresCorruption?, requiresFlag? }
   */
  const DIALOGUES = {
    // ─── OPENING SCENE: Silas warns about Concordat attack ───
    opening_silas: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: 'The Concordat knows we\'re here. I can smell the incense-and-blood on the wind. We have minutes before the gargoyles activate. I hope you\'re ready to get your hands dirty, Penitent.',
      choices: [
        { text: '"We sell their location to the Choir. We need an exit."', tag: 'betrayal', tagText: 'Betrayal',
          effect: () => { modStat('corruption',10); modTrust('silas',-5); modAxis('honor',-5); showNotification('Betrayal','Survival over loyalty. Corruption +10.'); loadDialogue('opening_betrayal'); } },
        { text: '"We stand and fight. No one gets left behind."', tag: 'redemption', tagText: 'Redemption',
          effect: () => { modTrust('silas',10); modTrust('magdalene',10); modAxis('honor',5); showNotification('Redemption','The party trusts you more. Honor +1.'); loadDialogue('opening_fight'); } },
        { text: '"Silas, I need you to trust me. Can you do that?"', tag: 'covenant', tagText: 'Covenant',
          effect: () => { modTrust('silas',15); modAxis('unity',5); showNotification('Covenant Forged','Silas gains +15 Trust. New dialogue unlocked.'); loadDialogue('opening_covenant'); } }
      ]
    },
    opening_betrayal: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: 'Cold. Practical. I\'d expect nothing less from a former Debt-Collector. But remember — the Choir has a price for everything. You\'re trading one debt for another.',
      choices: [
        { text: '"Debts I can manage. Death I cannot."', tag: 'covenant', tagText: 'Pragmatic', effect: () => { loadDialogue('opening_combat_start'); } },
        { text: '"Then let\'s not be here when they collect."', tag: 'betrayal', tagText: 'Flee', effect: () => { loadDialogue('opening_combat_start'); } }
      ]
    },
    opening_fight: {
      speaker: 'Magdalene', speakerId: 'magdalene',
      text: 'Spoken like someone who understands what family means. Silas — draw your blade. We\'ll show these gargoyles what happens when you corner the desperate.',
      choices: [
        { text: '"Together, then. On my mark."', tag: 'covenant', tagText: 'Lead', effect: () => { modTrust('magdalene',5); loadDialogue('opening_combat_start'); } },
        { text: '"Magdalene, guard the exit. Silas, with me."', tag: 'redemption', tagText: 'Command', effect: () => { modTrust('magdalene',5); loadDialogue('opening_combat_start'); } }
      ]
    },
    opening_covenant: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: '*pause* ...You\'re different from the others who\'ve worn that mask. Most Penitents beg for forgiveness. You\'re asking for trust. Dangerous gamble. But yes. Yes, I trust you. For now.',
      choices: [
        { text: '"That\'s all I need."', tag: 'covenant', tagText: 'Accept', effect: () => { loadDialogue('opening_combat_start'); } },
        { text: '[Echo] "Trust is just another chain." (requires corruption)', tag: 'echo', tagText: 'Echo', requiresCorruption: 20,
          effect: () => { modStat('corruption',5); modTrust('silas',-5); showNotification('Echo Whisper','The mask cracks slightly. Corruption +5.'); loadDialogue('opening_echo'); } }
      ]
    },
    opening_echo: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: '*backs away* That voice... that\'s not you. That\'s the Echo talking through your mask. I\'ve heard it before, in the depths. It promises truth but delivers only hunger. Be careful, Penitent. Be very careful.',
      choices: [
        { text: '"I\'m still in control."', tag: 'redemption', tagText: 'Reassure', effect: () => { modTrust('silas',5); loadDialogue('opening_combat_start'); } },
        { text: '"The Echo speaks truth Silas. You know it does."', tag: 'betrayal', tagText: 'Embrace', effect: () => { modStat('corruption',5); loadDialogue('opening_combat_start'); } }
      ]
    },
    opening_combat_start: {
      speaker: 'System', speakerId: 'gargoyle',
      text: 'The gargoyles descend. Their fiber-optic eyes blaze crimson as they lock onto your heat signatures. There is no more time for words.',
      choices: [
        { text: '[Enter Combat]', tag: 'covenant', tagText: 'Fight', effect: () => { startCombat(0); } }
      ]
    },

    // ─── HALL OF MIRRORS ENTRY: Orin's guidance ───
    hall_of_mirrors_orin: {
      speaker: 'Orin', speakerId: 'orin',
      text: 'The Hall of Mirrors waits ahead. It is not a place of stone and glass — it is a wound in reality. Every step you take inside, you will be asked to confront the self you have buried. I can guide you... but I cannot protect you from what you see.',
      choices: [
        { text: '"I\'ll go alone. This is my burden."', tag: 'redemption', tagText: 'Solo', effect: () => { modStat('corruption',10); showNotification('Solo Entry','Higher corruption, but personal revelation.'); loadDialogue('mirrors_enter'); } },
        { text: '"Come with me, Orin. I need your eyes."', tag: 'covenant', tagText: 'Companion', effect: () => { modTrust('orin',10); modStat('corruption',-5); showNotification('Guided Entry','Orin accompanies you. Trust deepened.'); loadDialogue('mirrors_orin_join'); } }
      ],
      requiresFlag: 'orin_unlocked'
    },
    mirrors_orin_join: {
      speaker: 'Orin', speakerId: 'orin',
      text: '*nods slowly* Very well. I will walk with you. But know this — what the mirrors show me may be different from what they show you. Do not be alarmed if I... react. The Hall speaks differently to Echo-touched souls.',
      choices: [
        { text: '"I trust you, Orin. Lead on."', tag: 'covenant', tagText: 'Trust', effect: () => { setRoom(1); loadDialogue('mirrors_inside'); } },
        { text: '"If you see something, warn me immediately."', tag: 'redemption', tagText: 'Caution', effect: () => { setRoom(1); loadDialogue('mirrors_inside'); } }
      ]
    },
    mirrors_enter: {
      speaker: 'System', speakerId: 'reflection',
      text: 'You step through the archway alone. The air shimmers, and suddenly there are infinite versions of yourself — stretching into eternity. Some wear crowns. Some wear chains. One turns to look at you directly.',
      choices: [
        { text: 'Approach the reflection that sees you.', tag: 'covenant', tagText: 'Confront', effect: () => { setRoom(1); loadDialogue('mirrors_inside'); } },
        { text: 'Shatter the nearest mirror.', tag: 'betrayal', tagText: 'Destroy', effect: () => { modAxis('honor',-5); setRoom(1); loadDialogue('mirrors_inside'); } }
      ]
    },
    mirrors_inside: {
      speaker: 'Your Reflection', speakerId: 'reflection',
      text: 'I am what you could have been. I am what you fear becoming. I am the truth you hide behind that mask. Will you shatter the glass, or shatter yourself?',
      choices: [
        { text: 'Shatter the mirrors. Power above all else.', tag: 'betrayal', tagText: 'Destroy',
          effect: () => { modAxis('honor',-10); addItem({ id:'shardblade', name:'Shardblade', type:'weapon', rarity:'epic', icon:'&#x1F5E1;', stats:{atk:25}, desc:'A blade of broken mirror. High damage, but it weakens bonds.' }); showNotification('Shardblade','You gained a powerful weapon. Trust weakened.'); setRoom(2); } },
        { text: 'Accept the reflections. Bonds deepen.', tag: 'redemption', tagText: 'Accept',
          effect: () => { modStat('corruption',15); modTrust('silas',5); modTrust('magdalene',5); addItem({ id:'mirrored_heart', name:'Mirrored Heart', type:'accessory', rarity:'rare', icon:'&#x1F5A4;', stats:{syn:3}, desc:'Boosts all social link gains by 25%.' }); showNotification('Mirrored Heart','Your party trusts you more. Corruption +15.'); setRoom(2); } }
      ]
    },

    // ─── IRON BASTION: Warden's secret ───
    bastion_discovery: {
      speaker: 'Magdalene', speakerId: 'magdalene',
      text: 'This place... I was imprisoned here. The Warden "re-educated" prisoners — stripped our memories, our emotions, fed them into the Concordat\'s machines. I barely escaped with my mind intact. And now we\'re walking right back in.',
      choices: [
        { text: '"We free every prisoner we find. No exceptions."', tag: 'redemption', tagText: 'Liberate', effect: () => { modAxis('honor',10); modTrust('magdalene',15); loadDialogue('bastion_liberate'); } },
        { text: '"We move quietly. Free them if we can, mission comes first."', tag: 'covenant', tagText: 'Stealth', effect: () => { modAxis('unity',5); loadDialogue('bastion_stealth'); } },
        { text: '"We use the chaos. Free them to distract the guards."', tag: 'betrayal', tagText: 'Sacrifice', effect: () => { modAxis('honor',-10); modTrust('magdalene',-10); loadDialogue('bastion_chaos'); } }
      ],
      requiresFlag: 'bastion_unlocked'
    },
    bastion_liberate: {
      speaker: 'Magdalene', speakerId: 'magdalene',
      text: '*her voice trembles* You... you mean that. After everything you\'ve seen — everything you\'ve done — you still choose to save people who can\'t repay you. Thank you. Thank you, Penitent.',
      choices: [
        { text: '"Everyone deserves a chance. Even me."', tag: 'redemption', tagText: 'Humility', effect: () => { modTrust('magdalene',10); startCombat(3); } },
        { text: '"Don\'t thank me yet. We still have to survive."', tag: 'covenant', tagText: 'Focus', effect: () => { startCombat(3); } }
      ]
    },
    bastion_stealth: {
      speaker: 'Silas', speakerId: 'silas',
      text: 'Smart. Sentimentality gets you killed down here. We free who we can, but if a prisoner compromises the mission... well. Hard choices, Penitent. That\'s why we pay you the big credits.',
      choices: [
        { text: '"I don\'t need credits. I need us alive."', tag: 'covenant', tagText: 'Survive', effect: () => { startCombat(2); } },
        { text: '"If you make that choice for me again, we\'re done."', tag: 'redemption', tagText: 'Warning', effect: () => { modTrust('silas',-5); startCombat(2); } }
      ]
    },
    bastion_chaos: {
      speaker: 'Magdalene', speakerId: 'magdalene',
      text: '*stares at you* You would use innocent people as... as bait? After what they did to me? After what they did to ALL of us? *she grips her weapon* I\'m starting to wonder whose side you\'re really on.',
      choices: [
        { text: '"The mission matters more than individuals."', tag: 'betrayal', tagText: 'Cold', effect: () => { modTrust('magdalene',-15); startCombat(2); } },
        { text: '"I\'m sorry. You\'re right. We do this together."', tag: 'redemption', tagText: 'Relent', effect: () => { modTrust('magdalene',5); modAxis('honor',5); startCombat(2); } }
      ]
    },

    // ─── ARENA INTRODUCTION: Broker Kael's contract ───
    arena_kael: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Welcome to the Pit, Penitent. I\'m Broker Kael — I own this hole, and everyone who bleeds in it. You want the Undercroft\'s support? Fine. Five matches. Win them all, and I\'ll consider your cause. Lose, and your debt becomes mine.',
      choices: [
        { text: '"I\'ll fight. All five matches. Myself."', tag: 'covenant', tagText: 'Accept', effect: () => { modAxis('honor',5); setRoom(3); loadDialogue('arena_match1'); } },
        { text: '"I\'ll fight, but on my terms. Not yours."', tag: 'redemption', tagText: 'Negotiate', effect: () => { modAxis('unity',5); setRoom(3); loadDialogue('arena_match1'); } },
        { text: '"Send my companion. I need to stay fresh."', tag: 'betrayal', tagText: 'Sacrifice', effect: () => { modTrust('silas',-10); setRoom(3); loadDialogue('arena_match1'); } }
      ],
      requiresFlag: 'arena_unlocked'
    },
    arena_match1: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Match One: The Novice. Young, scared, holding a blade for the first time. Show mercy, the crowd\'ll boo you out. End them, and you\'ll earn their respect. What\'ll it be, Penitent?',
      choices: [
        { text: 'Show mercy. Send the kid home.', tag: 'redemption', tagText: 'Mercy', effect: () => { modAxis('honor',10); showNotification('Crowd Boos','The crowd hates you. But you sleep better.'); loadDialogue('arena_match2'); } },
        { text: 'End the fight. The crowd demands blood.', tag: 'betrayal', tagText: 'Execute', effect: () => { modAxis('honor',-10); state.credits += 500; showNotification('Victory','+500 credits. Crowd roars.'); updateResources(); loadDialogue('arena_match2'); } }
      ]
    },
    arena_match2: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Match Two: The Veteran. Been here longer than I have. They\'re offering surrender — rare in the Pit. You can accept and gain an ally, or exploit their weakness for glory.',
      choices: [
        { text: 'Accept their surrender. Welcome them.', tag: 'covenant', tagText: 'Ally', effect: () => { modAxis('unity',10); showNotification('New Ally','The Veteran joins your cause.'); loadDialogue('arena_match3'); } },
        { text: 'No mercy. This is a fight, not a tea party.', tag: 'betrayal', tagText: 'Attack', effect: () => { state.credits += 800; showNotification('Victory','+800 credits.'); updateResources(); loadDialogue('arena_match3'); } }
      ]
    },
    arena_match3: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Match Three: The Pair. Two lovers, fighting as one. One is wounded — the other offers to die in their place. Beautiful, isn\'t it? You can let the sacrifice happen, or force them apart.',
      choices: [
        { text: 'Let love prevail. Honor their sacrifice.', tag: 'redemption', tagText: 'Honor', effect: () => { modAxis('honor',10); modTrust('magdalene',5); showNotification('Honored','You respected their bond.'); loadDialogue('arena_match4'); } },
        { text: 'Force them apart. No one dies today.', tag: 'covenant', tagText: 'Separate', effect: () => { modAxis('unity',5); showNotification('Separated','Both survive. But they hate you.'); loadDialogue('arena_match4'); } },
        { text: '"Let them both die. The crowd loves tragedy."', tag: 'betrayal', tagText: 'Cruel', effect: () => { modAxis('honor',-15); state.credits += 1000; showNotification('Cruel Victory','+1000 credits.'); updateResources(); loadDialogue('arena_match4'); } }
      ]
    },
    arena_match4: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Match Four: The Machine. A biomechanical construct with a human brain trapped inside. It begs for death. Destroying it is mercy. But it used to be a person — someone\'s child, someone\'s love.',
      choices: [
        { text: 'End its suffering. Mercy in steel.', tag: 'redemption', tagText: 'Mercy', effect: () => { modAxis('honor',5); showNotification('Released','The machine thanks you before fading.'); loadDialogue('arena_match5'); } },
        { text: 'Spare it. Every life deserves a chance.', tag: 'covenant', tagText: 'Spare', effect: () => { modStat('corruption',5); showNotification('Horror','The machine screams as you leave it.'); loadDialogue('arena_match5'); } }
      ]
    },
    arena_match5: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Final Match: The Undefeated. A former Concordat knight who has never killed. They refuse to. Break their vow and they\'ll be yours. Forfeit and accept exile. Or... convince them.',
      choices: [
        { text: 'Convince them to join. Peace over violence.', tag: 'redemption', tagText: 'Convince',
          effect: () => { if (state.honor >= 20) { showNotification('Success!','The Undefeated joins your party!'); modAxis('honor',10); } else { showNotification('Failed','Not enough honor. They refuse.'); } loadDialogue('arena_complete'); } },
        { text: 'Break their vow. Make them kill.', tag: 'betrayal', tagText: 'Break', effect: () => { modStat('corruption',20); addItem({ id:'oathbreaker', name:'Oathbreaker Blade', type:'weapon', rarity:'legendary', icon:'&#x2694;', stats:{atk:40}, desc:'Highest base damage. Lowers all party trust.' }); showNotification('Oathbreaker','You gained the legendary blade. +50 Corruption.'); loadDialogue('arena_complete'); } },
        { text: 'Forfeit. Some principles are worth more.', tag: 'covenant', tagText: 'Forfeit', effect: () => { modAxis('honor',15); showNotification('Exiled','You keep your honor. The tunnels are yours.'); loadDialogue('arena_complete'); } }
      ]
    },
    arena_complete: {
      speaker: 'Broker Kael', speakerId: 'kael',
      text: 'Five matches. Win or lose, you survived the Pit. Not many can say that. The Undercroft remembers its debts — and its allies. You have my support, Penitent. Use it wisely. Or don\'t. Your choice.',
      choices: [
        { text: '"I\'ll use it to burn the Concordat down."', tag: 'betrayal', tagText: 'Threaten', effect: () => { setRoom(0); } },
        { text: '"Thank you, Kael. I won\'t forget this."', tag: 'covenant', tagText: 'Gratitude', effect: () => { setRoom(0); } }
      ]
    },

    // ─── FINAL CONFRONTATION: Cardinal Vex 3-phase dialogue ───
    vex_phase1: {
      speaker: 'Cardinal Vex', speakerId: 'vex',
      text: 'You\'ve come far, Penitent. Further than I expected. But before we settle this, I want you to understand what you\'re trying to destroy. The Concordat ended the Echo Wars. We created peace where there was only chaos.',
      choices: [
        { text: '"By creating a worse war within."', tag: 'redemption', tagText: 'Counter',
          effect: () => { loadDialogue('vex_phase1_b'); } },
        { text: '"Order requires sacrifice — whose? Always the powerless."', tag: 'redemption', tagText: 'Accuse',
          effect: () => { loadDialogue('vex_phase1_b'); } },
        { text: '"You\'re doing what I lack the strength to do."', tag: 'betrayal', tagText: 'Agree',
          effect: () => { modStat('corruption',10); loadDialogue('vex_phase1_c'); } },
        { text: '[Echo] "I see through you, Vex. You\'re terrified."', tag: 'echo', tagText: 'Echo', requiresCorruption: 30,
          effect: () => { modStat('corruption',5); loadDialogue('vex_phase1_echo'); } }
      ],
      requiresFlag: 'vex_unlocked'
    },
    vex_phase1_b: {
      speaker: 'Cardinal Vex', speakerId: 'vex',
      text: 'Sharp words. But words don\'t feed the starving. Words don\'t stop the Echo from bleeding through. I\'ve seen what this city becomes without order. Have you? Have you seen the chaos that waits beyond the walls?',
      choices: [
        { text: '"I\'ve seen what your order does to people. That\'s enough."', tag: 'redemption', tagText: 'Defy', effect: () => { loadDialogue('vex_phase2'); } },
        { text: '"Show me. Prove your way is better."', tag: 'covenant', tagText: 'Listen', effect: () => { loadDialogue('vex_phase2'); } }
      ]
    },
    vex_phase1_c: {
      speaker: 'Cardinal Vex', speakerId: 'vex',
      text: 'At least you\'re honest. Most rebels hide behind moral pretense. But you... you understand the calculus. The many over the few. Order over chaos. We\'re not so different, you and I.',
      choices: [
        { text: '"We\'re nothing alike. I chose to stop."', tag: 'redemption', tagText: 'Reject', effect: () => { loadDialogue('vex_phase2'); } },
        { text: '"Maybe. But I have something you don\'t."', tag: 'covenant', tagText: 'Allies', effect: () => { modTrust('silas',5); modTrust('magdalene',5); loadDialogue('vex_phase2'); } }
      ]
    },
    vex_phase1_echo: {
      speaker: 'Cardinal Vex', speakerId: 'vex',
      text: '*flinches* The Echo... it speaks through you so clearly. I remember when it spoke to me. Before I built the walls. Before I became... this. Tell me, Penitent — does it promise you peace? It promised me peace. It lied.',
      choices: [
        { text: '"It doesn\'t promise. It shows. And I\'m still standing."', tag: 'redemption', tagText: 'Resolve', effect: () => { modStat('corruption',5); loadDialogue('vex_phase2'); } },
        { text: '"Then let\'s end this together. Both of us free."', tag: 'covenant', tagText: 'Offer', effect: () => { modTrust('vex',20); loadDialogue('vex_phase2'); } }
      ]
    },
    vex_phase2: {
      speaker: 'Cardinal Vex', speakerId: 'vex',
      text: 'Enough words. You could have been my successor, Penitent. The strongest debt-collector I ever trained. Why did you choose weakness? Why did you choose THEM? *His armor seals, neon crimson igniting along its seams.*',
      choices: [
        { text: '"Because strength without purpose is just cruelty."', tag: 'redemption', tagText: 'Challenge', effect: () => { startBossCombat(4); } },
        { text: '[Offer truce] "It\'s not too late, Vex."', tag: 'covenant', tagText: 'Truce', effect: () => { if (state.social.vex.trust >= 20) { showNotification('Truce','Vex hesitates. Phase 3 begins differently.'); } startBossCombat(4); } },
        { text: '"I chose humanity. Something you forgot."', tag: 'betrayal', tagText: 'Condemn', effect: () => { startBossCombat(4); } }
      ]
    },

    // ─── SILAS BETRAYAL (Act I ending beat) ───
    silas_betrayal: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: 'I know what you heard. I know what it looks like. But Lyra — they have Lyra. They said if I didn\'t tell them where you were, they\'d process her. You know what that means. You\'ve seen the tanks.',
      choices: [
        { text: '"You should have trusted me."', tag: 'redemption', tagText: 'Honor', effect: () => { loadDialogue('silas_betrayal_honor'); } },
        { text: '"I understand. But it can\'t happen again."', tag: 'covenant', tagText: 'Pragmatic', effect: () => { loadDialogue('silas_betrayal_pragmatic'); } },
        { text: '[Echo] "You used me. Now I use you."', tag: 'echo', tagText: 'Echo', requiresCorruption: 30, effect: () => { modStat('corruption',10); modTrust('silas',-20); showNotification('Fear','Silas becomes fearful but obedient.'); } },
        { text: '"Get out."', tag: 'betrayal', tagText: 'Exile', effect: () => { state.party = state.party.filter(m => m !== 'silas'); document.getElementById('member-silas').style.display = 'none'; showNotification('Exiled','Silas leaves the party.'); } }
      ]
    },
    silas_betrayal_honor: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: '"We\'re supposed to be in this together, Silas. Every secret you keep, every deal you make behind my back — it makes us weaker. I would have helped you." Silas looks down. "Would you? Would you really have risked everything for my sister?"',
      choices: [
        { text: '"Yes. Without hesitation."', tag: 'redemption', tagText: 'Vow', effect: () => { modTrust('silas',25); showNotification('Devotion','Silas trusts you completely.'); } },
        { text: '"I don\'t know. But we should have faced it together."', tag: 'covenant', tagText: 'Honest', effect: () => { modTrust('silas',10); showNotification('Understanding','Silas partially opens up.'); } }
      ]
    },
    silas_betrayal_pragmatic: {
      speaker: 'Silas Vane', speakerId: 'silas',
      text: '"I\'ve done terrible things for people I care about too. I get it. But if we\'re going to survive, I need to know I can count on you." Silas meets your eyes. "You can. From now on. I swear on her life."',
      choices: [
        { text: '"I believe you."', tag: 'covenant', tagText: 'Trust', effect: () => { modTrust('silas',15); modAxis('unity',10); showNotification('Loyalty','Silas gains combat buff.'); } },
        { text: '"Words are cheap. Prove it."', tag: 'redemption', tagText: 'Test', effect: () => { modTrust('silas',5); showNotification('Guarded','Silas accepts your terms.'); } }
      ]
    },

    // ─── ORIN'S REVELATION (Act II ending beat) ───
    orin_revelation: {
      speaker: 'Orin', speakerId: 'orin',
      text: 'I see threads, Penitent. Threads between events that look like coincidence. Your defection was... assisted. Someone wanted you in the underworld. Someone with power over both the Concordat and the Echo.',
      choices: [
        { text: '"Who? I need to know who manipulated me."', tag: 'redemption', tagText: 'Honor', effect: () => { modTrust('orin',15); showNotification('Quest','Unlocks Shadow Player investigation.'); } },
        { text: '"Does it matter? I\'m here. The Concordat needs to be stopped."', tag: 'covenant', tagText: 'Pragmatic', effect: () => { modTrust('orin',10); } },
        { text: '[Echo] "I can see them too, Orin."', tag: 'echo', tagText: 'Echo', requiresCorruption: 50, effect: () => { loadDialogue('orin_revelation_echo'); } }
      ]
    },
    orin_revelation_echo: {
      speaker: 'Orin', speakerId: 'orin',
      text: 'Your eyes glow. The Echo shows you fragmented visions. Orin steps back. "The Echo shows you truth mixed with desire. Be careful what you believe."',
      choices: [
        { text: '"The Echo shows me YOU, Orin. You\'re the puppeteer."', tag: 'betrayal', tagText: 'Accuse', effect: () => { modTrust('orin',-30); showNotification('Betrayal','Orin does not deny it.'); } },
        { text: '"I see... a child. In a mask."', tag: 'covenant', tagText: 'Reveal', effect: () => { showNotification('Mystery','Orin goes silent.'); } }
      ]
    },

    // ─── DEFAULT / EXPLORATION DIALOGUES ───
    default_npc: {
      speaker: 'Hollow Choir Member', speakerId: 'orin',
      text: 'The Choir sees you, Penitent. We see the weight of debts collected. We see the cracks in your mask. Will you share your truth with us, or hide behind silence?',
      choices: [
        { text: '"I have nothing to hide."', tag: 'covenant', tagText: 'Open', effect: () => { modTrust('orin',5); } },
        { text: '"My truths are my own."', tag: 'redemption', tagText: 'Guarded', effect: () => { } },
        { text: '[Say nothing]', tag: 'betrayal', tagText: 'Silent', effect: () => { modStat('corruption',5); } }
      ]
    },
    default_explore: {
      speaker: 'System', speakerId: 'protagonist',
      text: 'The fog shifts around you. Bioluminescent vines pulse with faint light. Somewhere in the distance, a neon sign flickers — a single word: "VESPERA". Something watches from the shadows.',
      choices: [
        { text: 'Continue searching.', tag: 'covenant', tagText: 'Explore', effect: () => { state.xp += 10; checkLevelUp(); } },
        { text: 'Rest and recover.', tag: 'redemption', tagText: 'Rest', effect: () => { healParty(20); } },
        { text: 'Follow the neon glow.', tag: 'betrayal', tagText: 'Pursue', effect: () => { state.credits += 100; updateResources(); } }
      ]
    }
  };

  // ═══════════════════════════════════════════════════════════════
  // DIALOGUE LOADING & RENDERING
  // ═══════════════════════════════════════════════════════════════
  function loadDialogue(key) {
    const dia = DIALOGUES[key];
    if (!dia) {
      // Fallback to default
      loadDialogue('default_explore');
      return;
    }

    state.currentDialogue = key;

    // Check flag requirements
    if (dia.requiresFlag && !state.flags[dia.requiresFlag]) {
      loadDialogue('default_explore');
      return;
    }

    // Update speaker
    const speakerEl = document.getElementById('dialogueSpeaker');
    const speakerImg = document.getElementById('speakerImg');
    const speakerName = document.getElementById('speakerName');

    if (speakerImg) {
      const imgPath = SPEAKER_IMAGES[dia.speakerId] || 'sprites/protagonist_front.png';
      speakerImg.src = imgPath;
      speakerImg.style.display = '';
    }
    if (speakerName) speakerName.textContent = dia.speaker;

    // Start typewriter
    const textEl = document.getElementById('typewriterText');
    if (textEl) textEl.textContent = '';
    state.isTyping = true;

    // Hide combat controls, show dialogue
    document.getElementById('dialogueBox').style.display = '';
    document.getElementById('combatControls').style.display = 'none';

    let i = 0;
    function typeChar() {
      if (i < dia.text.length) {
        if (textEl) textEl.textContent += dia.text.charAt(i);
        i++;
        setTimeout(typeChar, state.settings.textSpeed);
      } else {
        state.isTyping = false;
        renderChoices(dia.choices);
      }
    }
    typeChar();
    document.getElementById('dialogueChoices').innerHTML = '';
  }

  function renderChoices(choices) {
    const container = document.getElementById('dialogueChoices');
    container.innerHTML = '';
    if (!choices) return;

    choices.forEach(choice => {
      // Check corruption requirement for Echo choices
      if (choice.requiresCorruption && state.corruption < choice.requiresCorruption) {
        return; // Skip this choice
      }

      const btn = document.createElement('button');
      btn.className = 'choice-btn';
      if (choice.tag === 'echo') btn.classList.add('hidden-echo');
      if (choice.tag === 'echo' && state.corruption >= (choice.requiresCorruption || 0)) {
        btn.classList.add('visible');
      }

      const tagClass = {
        betrayal: 'tag-betrayal', redemption: 'tag-redemption',
        covenant: 'tag-covenant', echo: 'tag-echo'
      }[choice.tag] || 'tag-covenant';

      btn.innerHTML = `<span class="choice-tag ${tagClass}">${choice.tagText}</span><span>${choice.text}</span>`;
      btn.onclick = () => {
        if (state.isTyping) return;
        if (choice.effect) choice.effect();
      };
      container.appendChild(btn);
    });
  }

  // ═══════════════════════════════════════════════════════════════
  // COMBAT SYSTEM — Stances, Actions, Enemy AI, Damage
  // ═══════════════════════════════════════════════════════════════

  function startCombat(enemyIndex) {
    const enemyTemplate = ENEMIES[enemyIndex] || ENEMIES[0];
    state.currentEnemy = {
      ...enemyTemplate,
      hp: enemyTemplate.maxHp,
      phase: enemyTemplate.phases ? 1 : 0
    };
    state.inCombat = true;
    state.combatTurn = 'player';

    // Show combat viewport
    document.getElementById('combatViewport').classList.add('active');
    document.getElementById('roomContent').style.opacity = '0.3';
    document.getElementById('dialogueBox').style.display = 'none';
    document.getElementById('combatControls').style.display = '';

    // Update enemy display
    document.getElementById('enemyImg').src = state.currentEnemy.img;
    document.getElementById('enemyName').textContent = state.currentEnemy.name;
    updateEnemyHP();

    // Clear combat log
    document.getElementById('combatLog').innerHTML = '';
    addCombatLog(`Combat started: ${state.currentEnemy.name}!`);

    showNotification('Combat Started', `${state.currentEnemy.name} lunges forward!`);
  }

  function startBossCombat(enemyIndex) {
    startCombat(enemyIndex);
    showNotification('BOSS BATTLE', 'Your sins have caught up with you.');
  }

  function endCombat(won) {
    state.inCombat = false;
    state.combatTurn = 'player';
    document.getElementById('combatViewport').classList.remove('active');
    document.getElementById('roomContent').style.opacity = '1';
    document.getElementById('combatControls').style.display = 'none';
    document.getElementById('dialogueBox').style.display = '';

    if (won) {
      const xp = state.currentEnemy.xp || 50;
      state.xp += xp;
      addCombatLog(`Victory! Gained ${xp} XP.`);
      showNotification('Victory!', `Defeated ${state.currentEnemy.name}. +${xp} XP.`);

      // Loot
      if (state.currentEnemy.loot) {
        const lootTable = {
          gargoyle_core: { name: 'Gargoyle Core', type: 'key', rarity: 'uncommon', icon: '&#x1F48E;', desc: 'Biomechanical heart. Sells for 200 credits.' },
          enforcer_badge: { name: 'Enforcer Badge', type: 'key', rarity: 'rare', icon: '&#x1F6E1;', desc: 'Proof of Concordat rank. Useful for infiltration.' },
          echo_shard: { name: 'Echo Shard', type: 'consumable', rarity: 'uncommon', icon: '&#x2728;', desc: 'Raw emotional energy. +20 MP.', effect: { mp: 20 } },
          warden_key: { name: 'Warden\'s Key', type: 'key', rarity: 'epic', icon: '&#x1F511;', desc: 'Unlocks all Concordat security doors.' },
          vex_signet: { name: 'Vex\'s Signet', type: 'key', rarity: 'legendary', icon: '&#x1F48D;', desc: 'The Cardinal\'s ring. It pulses with trapped power.' }
        };
        const loot = lootTable[state.currentEnemy.loot];
        if (loot) {
          addItem(loot);
          showNotification('Loot Found', `Obtained: ${loot.name}`);
        }
      }

      checkLevelUp();

      // Boss-specific post-combat
      if (state.currentEnemy.boss && state.currentEnemy.name === 'Cardinal Vex') {
        loadDialogue('vex_phase3');
        return;
      }
      if (state.currentEnemy.boss && state.currentEnemy.name === 'The Warden') {
        loadDialogue('warden_aftermath');
        return;
      }

      loadDialogue('default_explore');
    } else {
      showNotification('Defeat', 'Your vision fades to black...');
      // Reset to last room
      healParty(50);
      loadDialogue('default_explore');
    }

    state.currentEnemy = null;
  }

  function combatAttack() {
    if (!state.inCombat || state.combatTurn !== 'player') return;

    const stanceMultipliers = { penitent: 0.9, inquisitor: 1.3, heretic: 1.1 };
    const baseDmg = 10 + state.stats.frc * 2;
    const stanceMult = stanceMultipliers[state.stance] || 1;
    const variance = 0.8 + Math.random() * 0.4;
    const critChance = state.stats.vel * 0.02;
    const isCrit = Math.random() < critChance;
    const critMult = isCrit ? 2 : 1;

    let dmg = Math.floor(baseDmg * stanceMult * variance * critMult);
    if (state.echoActive) dmg = Math.floor(dmg * 1.5);

    // Deal damage
    state.currentEnemy.hp = Math.max(0, state.currentEnemy.hp - dmg);
    updateEnemyHP();

    // Show damage number
    showDamage(dmg, isCrit ? 'crit' : 'normal');
    addCombatLog(`You dealt ${dmg} damage!${isCrit ? ' CRITICAL!' : ''}`);

    if (state.currentEnemy.hp <= 0) {
      if (state.currentEnemy.phases && state.currentEnemy.phase < state.currentEnemy.phases) {
        // Next phase
        state.currentEnemy.phase++;
        state.currentEnemy.hp = Math.floor(state.currentEnemy.maxHp * 0.5);
        addCombatLog(`PHASE ${state.currentEnemy.phase}! ${state.currentEnemy.name} transforms!`);
        showNotification('Phase Shift', 'The enemy reveals its true form!');
        updateEnemyHP();
      } else {
        endCombat(true);
        return;
      }
    }

    // Echo corruption for Heretic stance
    if (state.stance === 'heretic') {
      modStat('corruption', 2);
    }

    state.combatTurn = 'enemy';
    setTimeout(enemyTurn, 800);
  }

  function combatSkill() {
    if (!state.inCombat || state.combatTurn !== 'player') return;

    const skills = {
      penitent: { name: 'Penance Shield', effect: () => { showNotification('Shield','40% damage reduction for 2 turns.'); } },
      inquisitor: { name: 'Crimson Strike', effect: () => {
        const dmg = Math.floor((20 + state.stats.frc * 3) * 1.5);
        state.currentEnemy.hp = Math.max(0, state.currentEnemy.hp - dmg);
        updateEnemyHP(); showDamage(dmg, 'crit'); addCombatLog(`Crimson Strike! ${dmg} damage!`);
        if (state.currentEnemy.hp <= 0) { endCombat(true); return; }
      }},
      heretic: { name: 'Echo Blast', effect: () => {
        const dmg = Math.floor((15 + state.stats.syn * 3) * 1.3);
        state.currentEnemy.hp = Math.max(0, state.currentEnemy.hp - dmg);
        updateEnemyHP(); showDamage(dmg, 'echo'); addCombatLog(`Echo Blast! ${dmg} damage!`);
        modStat('corruption', 5);
        if (state.currentEnemy.hp <= 0) { endCombat(true); return; }
      }}
    };

    const skill = skills[state.stance];
    if (skill) skill.effect();

    state.combatTurn = 'enemy';
    setTimeout(enemyTurn, 800);
  }

  function combatDefend() {
    if (!state.inCombat || state.combatTurn !== 'player') return;
    showNotification('Defend', 'Damage taken reduced by 60% this turn.');
    addCombatLog('You brace for impact.');
    state.combatTurn = 'enemy';
    setTimeout(() => enemyTurn(0.4), 800);
  }

  function combatFlee() {
    if (!state.inCombat) return;
    if (state.currentEnemy && state.currentEnemy.boss) {
      showNotification('Cannot Flee', 'Boss battles cannot be escaped!');
      return;
    }
    const fleeChance = 0.3 + state.stats.vel * 0.03;
    if (Math.random() < fleeChance) {
      addCombatLog('You escaped into the fog!');
      state.inCombat = false;
      document.getElementById('combatViewport').classList.remove('active');
      document.getElementById('roomContent').style.opacity = '1';
      document.getElementById('combatControls').style.display = 'none';
      document.getElementById('dialogueBox').style.display = '';
      showNotification('Escaped', 'You retreated into the shadows.');
    } else {
      addCombatLog('Escape failed!');
      state.combatTurn = 'enemy';
      setTimeout(enemyTurn, 600);
    }
  }

  function enemyTurn(damageMod) {
    if (!state.inCombat || !state.currentEnemy) return;
    damageMod = damageMod || 1;

    const baseDmg = state.currentEnemy.dmg;
    const variance = 0.8 + Math.random() * 0.4;
    let dmg = Math.floor(baseDmg * variance * damageMod);

    // Defense reduction
    const defReduction = state.stats.vit * 0.02;
    dmg = Math.max(1, Math.floor(dmg * (1 - defReduction)));

    // Apply damage to protagonist
    const hpBar = document.getElementById('p1-hp');
    const hpText = document.getElementById('p1-hp-text');
    const combatHpFill = document.getElementById('playerCombatHp');
    const currentHP = parseInt(hpText.textContent.split('/')[0]);
    const maxHP = parseInt(hpText.textContent.split('/')[1]);
    const newHP = Math.max(0, currentHP - dmg);

    hpBar.style.width = (newHP / maxHP * 100) + '%';
    hpText.textContent = `${newHP}/${maxHP}`;
    if (combatHpFill) combatHpFill.style.width = (newHP / maxHP * 100) + '%';

    showDamage(dmg, 'normal', true);
    addCombatLog(`${state.currentEnemy.name} deals ${dmg} damage!`);

    if (newHP <= 0) {
      endCombat(false);
      return;
    }

    state.combatTurn = 'player';
  }

  function updateEnemyHP() {
    if (!state.currentEnemy) return;
    const pct = (state.currentEnemy.hp / state.currentEnemy.maxHp * 100);
    document.getElementById('enemyHpBar').style.width = pct + '%';
  }

  function showDamage(amount, type, isPlayer) {
    const container = document.getElementById('combatViewport');
    const dmgEl = document.createElement('div');
    dmgEl.className = 'damage-text';
    dmgEl.textContent = amount;

    if (type === 'crit') dmgEl.classList.add('damage-crit');
    else if (type === 'heal') dmgEl.classList.add('damage-heal');
    else if (type === 'echo') dmgEl.classList.add('damage-echo');
    else dmgEl.classList.add('damage-normal');

    if (isPlayer) {
      dmgEl.style.left = '20%';
      dmgEl.style.top = '60%';
    } else {
      dmgEl.style.left = '50%';
      dmgEl.style.top = '30%';
    }

    container.appendChild(dmgEl);
    setTimeout(() => dmgEl.remove(), 1200);
  }

  function addCombatLog(text) {
    const log = document.getElementById('combatLog');
    const entry = document.createElement('div');
    entry.className = 'combat-log-entry';
    entry.textContent = `> ${text}`;
    log.insertBefore(entry, log.firstChild);
    while (log.children.length > 6) log.removeChild(log.lastChild);
  }

  function setStance(stance) {
    state.stance = stance;
    document.querySelectorAll('.stance-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.stance === stance);
    });
    showNotification('Stance Changed', stance[0].toUpperCase() + stance.slice(1) + ' stance active.');
  }

  function toggleItemPanel() {
    document.getElementById('itemPanel').classList.toggle('active');
  }

  // ═══════════════════════════════════════════════════════════════
  // SOCIAL LINKS (Covenant Threads)
  // ═══════════════════════════════════════════════════════════════
  function modTrust(character, amount) {
    if (!state.social[character]) return;
    const link = state.social[character];
    if (!link.unlocked && amount > 0) link.unlocked = true;
    link.trust = Math.max(0, Math.min(100, link.trust + amount));
    updateRank(character);
    updateSocialDisplay();

    if (link.trust >= 75) {
      showNotification('Covenant Deepened', `${link.name} has reached maximum trust!`);
    } else if (link.trust <= 0 && amount < 0) {
      showNotification('Covenant Broken', `${link.name} may abandon you!`);
    }
  }

  function updateRank(character) {
    const link = state.social[character];
    const titles = RANK_TITLES[character] || RANK_TITLES.silas;
    const thresholds = [0, 15, 30, 45, 60, 75, 100];
    let newRank = 1;
    for (let i = 0; i < thresholds.length; i++) {
      if (link.trust >= thresholds[i]) newRank = i + 1;
    }
    if (newRank !== link.rank) {
      link.rank = newRank;
      link.rankName = titles[Math.min(newRank - 1, titles.length - 1)];
      if (newRank >= 3) {
        showNotification('Rank Up!', `${link.name} is now: ${link.rankName}`);
      }
    } else {
      link.rankName = titles[Math.min(link.rank - 1, titles.length - 1)];
    }
  }

  function updateSocialDisplay() {
    Object.keys(state.social).forEach(key => {
      const link = state.social[key];
      const bar = document.getElementById(`${key}-trust-bar`);
      const rank = document.getElementById(`${key}-rank`);
      if (bar) bar.style.width = link.trust + '%';
      if (rank) rank.textContent = link.unlocked ? `Rank ${link.rank} — ${link.rankName}` : 'Unknown';
    });
  }

  function renderSocialLinks() {
    const grid = document.getElementById('socialGrid');
    grid.innerHTML = '';
    Object.keys(state.social).forEach(key => {
      const link = state.social[key];
      if (!link.unlocked && key !== 'silas' && key !== 'magdalene') return;

      const card = document.createElement('div');
      card.className = 'social-card';
      const imgPath = SPEAKER_IMAGES[key] || 'sprites/protagonist_front.png';

      card.innerHTML = `
        <div class="social-card-header">
          <img class="social-card-img" src="${imgPath}" alt="${link.name}">
          <div class="social-card-info">
            <h3>${link.name}</h3>
            <div class="role">${link.role}</div>
          </div>
        </div>
        <div class="rank-display">Rank ${link.rank} — ${link.rankName}</div>
        <div class="trust-meter">
          <div class="trust-label"><span>Trust</span><span>${link.trust}/100</span></div>
          <div class="trust-bar"><div class="trust-fill" style="width:${link.trust}%"></div></div>
        </div>
        <div class="social-desc">${getSocialDesc(key, link.trust)}</div>
      `;
      grid.appendChild(card);
    });
  }

  function getSocialDesc(key, trust) {
    const descs = {
      silas: trust < 25 ? 'Silas watches you carefully. He trusts no one, not even himself.' :
             trust < 50 ? 'Silas has begun to open up. He shares small truths.' :
             trust < 75 ? 'Silas considers you a true ally. He would risk much for you.' :
             'Silas would die for you. His loyalty is absolute — and terrifying.',
      magdalene: trust < 25 ? 'Magdalene follows orders, but her eyes hold doubt.' :
                   trust < 50 ? 'Magdalene stands beside you without question.' :
                   trust < 75 ? 'Magdalene believes in your cause. She fights for YOU, not just the mission.' :
                   'Magdalene has sworn her life to you. An oath that cannot be broken.',
      orin: trust < 25 ? 'Orin watches from the shadows. Uncertain. Curious.' :
            trust < 50 ? 'Orin walks with you. The Echo approves.' :
            trust < 75 ? 'Orin shares secrets of the Echo Realm. You are becoming alike.' :
            'Orin sees you as a kindred spirit. Twin flames in the dark.',
      vex: trust < 25 ? 'Cardinal Vex hunts you. There is only enmity between you.' :
           trust < 50 ? 'Vex regards you with grudging respect.' :
           trust < 75 ? 'Vex considers your words before dismissing them.' :
           'Vex sees himself in you. The greatest danger of all.'
    };
    return descs[key] || 'A mystery yet to unfold.';
  }

  // ═══════════════════════════════════════════════════════════════
  // DUNGEON PROGRESSION
  // ═══════════════════════════════════════════════════════════════
  function setRoom(index) {
    state.currentRoom = index;
    if (!state.roomsVisited.includes(index)) state.roomsVisited.push(index);
    const room = ROOMS[index];

    document.getElementById('roomVisual').innerHTML = room.icon;
    document.getElementById('roomTitle').textContent = room.title;
    document.getElementById('roomDesc').textContent = room.desc;
    document.getElementById('locationName').textContent = room.title.split(' — ')[0];
    document.getElementById('locationSub').textContent = room.sub;
    document.getElementById('roomBgImage').style.backgroundImage = `url('${ROOM_IMAGES[index]}')`;

    // Update mini-map
    document.querySelectorAll('.map-node').forEach((node, i) => {
      node.className = 'map-node' + (i === index ? ' current' : state.roomsVisited.includes(i) ? ' visited' : '') + (i === ROOMS.length - 1 ? ' boss' : '');
    });

    // Restore room actions
    document.getElementById('roomActions').innerHTML = `
      <button class="room-btn" onclick="Game.exploreRoom()">&#x1F50D; Explore</button>
      <button class="room-btn" onclick="Game.enterCombat()">&#x2694; Combat</button>
      <button class="room-btn" onclick="Game.talkToNPC()">&#x1F4AC; Talk</button>
      <button class="room-btn" onclick="Game.moveRoom()">&#x1F6AA; Move</button>
    `;

    showNotification('Location Changed', `Entered: ${room.title}`);
  }

  function exploreRoom() {
    const roomId = ROOMS[state.currentRoom].id;
    const roll = Math.random();

    if (roll < 0.3) {
      // Find item
      const found = state.inventory[Math.floor(Math.random() * state.inventory.length)];
      showNotification('Found', `Discovered: ${found.name}`);
      state.xp += 15;
      checkLevelUp();
    } else if (roll < 0.5) {
      // Random combat
      loadDialogue('combat_ambush');
    } else if (roll < 0.7) {
      // Dialogue
      const roomDialogues = {
        ribcage: 'default_explore',
        mirrors: 'mirrors_inside',
        bastion: 'bastion_discovery',
        arena: 'arena_kael',
        cathedral: 'vex_phase1'
      };
      loadDialogue(roomDialogues[roomId] || 'default_explore');
    } else {
      // Credits
      const found = Math.floor(Math.random() * 100) + 50;
      state.credits += found;
      updateResources();
      showNotification('Scavenged', `Found ${found} credits in the rubble.`);
    }
  }

  function enterCombat() {
    const enemies = [0, 1, 2]; // gargoyle, enforcer, echo husk
    const enemyIdx = enemies[Math.floor(Math.random() * enemies.length)];
    startCombat(enemyIdx);
  }

  function talkToNPC() {
    const roomId = ROOMS[state.currentRoom].id;
    const roomDialogues = {
      ribcage: 'opening_silas',
      mirrors: 'hall_of_mirrors_orin',
      bastion: 'bastion_discovery',
      arena: 'arena_kael',
      cathedral: 'vex_phase1'
    };
    loadDialogue(roomDialogues[roomId] || 'default_npc');
  }

  function moveRoom() {
    const next = (state.currentRoom + 1) % ROOMS.length;
    setRoom(next);

    // Unlock flags for new areas
    if (next === 1) state.flags.orin_unlocked = true;
    if (next === 2) state.flags.bastion_unlocked = true;
    if (next === 3) state.flags.arena_unlocked = true;
    if (next === 4) state.flags.vex_unlocked = true;
  }

  function selectPartyMember(member) {
    state.activePartyMember = member;
    document.querySelectorAll('.party-member').forEach(m => {
      m.classList.toggle('active', m.dataset.member === member);
    });
  }

  // ═══════════════════════════════════════════════════════════════
  // UTILITY: Notifications, Resources, Healing, XP
  // ═══════════════════════════════════════════════════════════════
  function showNotification(title, text) {
    const area = document.getElementById('notificationArea');
    const notif = document.createElement('div');
    notif.className = 'notification';
    notif.innerHTML = `<div class="notification-title">${title}</div><div class="notification-text">${text}</div>`;
    area.appendChild(notif);
    setTimeout(() => notif.remove(), 3500);
  }

  function updateResources() {
    document.getElementById('creditsVal').textContent = state.credits.toLocaleString();
    document.getElementById('essenceVal').textContent = state.essence;
    document.getElementById('contractsVal').textContent = state.contracts;
  }

  function healParty(amount) {
    const ids = ['p1-hp', 'silas-hp', 'magdalene-hp', 'orin-hp'];
    const texts = ['p1-hp-text', 'silas-hp-text', 'magdalene-hp-text', 'orin-hp-text'];
    const maxHPs = [100 + state.stats.vit * 10, 80, 120, 60];

    ids.forEach((id, i) => {
      const bar = document.getElementById(id);
      const text = document.getElementById(texts[i]);
      if (!bar || !text) return;
      const current = parseInt(text.textContent.split('/')[0]);
      const max = parseInt(text.textContent.split('/')[1]) || maxHPs[i];
      const newHP = Math.min(max, current + amount);
      bar.style.width = (newHP / max * 100) + '%';
      text.textContent = `${newHP}/${max}`;
      // Update combat HP bar for protagonist (index 0)
      if (i === 0) {
        const combatHpFill = document.getElementById('playerCombatHp');
        if (combatHpFill) combatHpFill.style.width = (newHP / max * 100) + '%';
      }
    });
  }

  function updateHPDisplay() {
    const maxHP = 100 + state.stats.vit * 10;
    document.getElementById('p1-hp-text').textContent = `${maxHP}/${maxHP}`;
    document.getElementById('p1-mp-text').textContent = `${50 + state.stats.syn * 5}/${50 + state.stats.syn * 5}`;
    document.getElementById('partyLevel1').textContent = `Lv.${state.level}`;
    document.getElementById('chapterLabel').textContent = `Chapter ${state.chapter}`;
    document.getElementById('chapterTitle').textContent = state.chapterTitle;
    // Update combat player HP bar
    const combatHpFill = document.getElementById('playerCombatHp');
    if (combatHpFill) combatHpFill.style.width = '100%';
  }

  function updateCorruptionDisplay() {
    document.getElementById('echoPercent').textContent = state.corruption + '%';
    const mask = document.getElementById('echoMask');
    mask.className = 'echo-mask';
    if (state.corruption >= 25) mask.classList.add('corrupted-25');
    if (state.corruption >= 50) mask.classList.add('corrupted-50');
    if (state.corruption >= 75) mask.classList.add('corrupted-75');
    if (state.corruption >= 100) mask.classList.add('corrupted-100');

    const labels = [
      'The mask holds...', 'Hairline fractures...', 'The mask cracks...',
      'Shards falling...', 'The mask breaks. Truth revealed.'
    ];
    const idx = Math.min(Math.floor(state.corruption / 25), 4);
    const label = document.getElementById('echoLabel');
    if (label) label.textContent = labels[idx];
  }

  function modStat(stat, amount) {
    if (stat === 'corruption') {
      state.corruption = Math.max(0, Math.min(100, state.corruption + amount));
      updateCorruptionDisplay();
      document.getElementById('corruptionBar').style.width = state.corruption + '%';
      if (document.getElementById('corruptionValue')) {
        document.getElementById('corruptionValue').textContent = state.corruption + '%';
      }
    }
  }

  function modAxis(axis, amount) {
    state[axis] = Math.max(-100, Math.min(100, state[axis] + amount));
  }

  function checkLevelUp() {
    if (state.xp >= state.xpToNext) {
      state.level++;
      state.xp -= state.xpToNext;
      state.xpToNext = Math.floor(state.xpToNext * 1.5);
      state.skillPoints++;
      showNotification('Level Up!', `Reached Level ${state.level}! +1 Skill Point.`);
      updateHPDisplay();
      // Restore HP/MP
      healParty(999);
    }
  }

  function addItem(item) {
    const existing = state.inventory.find(i => i.id === item.id);
    if (existing && item.type === 'consumable') {
      existing.count = (existing.count || 1) + 1;
    } else {
      state.inventory.push({ ...item, count: 1, equipped: false });
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // SKILL TREE SYSTEM
  // ═══════════════════════════════════════════════════════════════
  function switchSkillBranch(branch) {
    document.querySelectorAll('.skill-tab').forEach(t => t.classList.remove('active'));
    document.querySelector(`.skill-tab.${branch}-tab`).classList.add('active');
    renderSkillTree(branch);
  }

  function renderSkillTree(activeBranch) {
    activeBranch = activeBranch || 'combat';
    const container = document.getElementById('skillTreeContainer');
    document.getElementById('skillPoints').textContent = state.skillPoints;

    let html = '';
    const tiers = [1, 2, 3];
    tiers.forEach(tier => {
      const tierSkills = SKILL_TREE[activeBranch].filter(s => s.tier === tier);
      html += `<div class="skill-tier">`;
      tierSkills.forEach(skill => {
        const isUnlocked = state.skills[skill.id];
        const canUnlock = canUnlockSkill(skill);
        const nodeClass = `${activeBranch}-node ${isUnlocked ? 'unlocked' : ''} ${!canUnlock && !isUnlocked ? 'locked' : ''}`;

        html += `
          <div class="skill-node ${nodeClass}" onclick="Game.unlockSkill('${skill.id}')">
            <span class="skill-node-icon">${isUnlocked ? '&#x2714;' : '&#x25C6;'}</span>
            <span class="skill-node-name">${skill.name}</span>
            <div class="skill-tooltip">
              <div class="skill-name">${skill.name}</div>
              <div class="skill-desc">${skill.desc}</div>
              <div class="skill-cost">Cost: ${skill.cost} point${skill.cost > 1 ? 's' : ''}</div>
              ${skill.prereq ? `<div>Requires: ${getSkillName(skill.prereq)}</div>` : ''}
            </div>
          </div>
        `;
      });
      html += `</div>`;
    });

    container.innerHTML = html;
  }

  function canUnlockSkill(skill) {
    if (state.skills[skill.id]) return false;
    if (state.skillPoints < skill.cost) return false;
    if (skill.prereq && !state.skills[skill.prereq]) return false;
    return true;
  }

  function unlockSkill(skillId) {
    const allSkills = [...SKILL_TREE.combat, ...SKILL_TREE.echo, ...SKILL_TREE.social];
    const skill = allSkills.find(s => s.id === skillId);
    if (!skill) return;
    if (!canUnlockSkill(skill)) {
      if (state.skills[skillId]) showNotification('Already Known', `${skill.name} is already unlocked.`);
      else if (state.skillPoints < skill.cost) showNotification('Not Enough Points', `Need ${skill.cost} skill point(s).`);
      else showNotification('Locked', `Requires: ${getSkillName(skill.prereq)}`);
      return;
    }

    state.skills[skillId] = true;
    state.skillPoints -= skill.cost;
    state.unlockedSkills.push(skillId);
    showNotification('Skill Unlocked', `${skill.name}: ${skill.desc}`);

    // Re-render
    const activeTab = document.querySelector('.skill-tab.active');
    const branch = activeTab.classList.contains('combat-tab') ? 'combat' :
                    activeTab.classList.contains('echo-tab') ? 'echo' : 'social';
    renderSkillTree(branch);
  }

  function getSkillName(id) {
    const allSkills = [...SKILL_TREE.combat, ...SKILL_TREE.echo, ...SKILL_TREE.social];
    const skill = allSkills.find(s => s.id === id);
    return skill ? skill.name : id;
  }

  // ═══════════════════════════════════════════════════════════════
  // INVENTORY SYSTEM
  // ═══════════════════════════════════════════════════════════════
  let currentInvFilter = 'all';

  function switchInvTab(filter) {
    currentInvFilter = filter;
    document.querySelectorAll('.inv-tab').forEach(t => t.classList.remove('active'));
    document.querySelector(`[onclick="Game.switchInvTab('${filter}')"]`).classList.add('active');
    renderInventory();
  }

  function renderInventory() {
    const grid = document.getElementById('inventoryGrid');
    grid.innerHTML = '';

    const filtered = currentInvFilter === 'all'
      ? state.inventory
      : state.inventory.filter(item => item.type === currentInvFilter);

    // Show 48 slots (8x6)
    for (let i = 0; i < 48; i++) {
      const item = filtered[i];
      const slot = document.createElement('div');
      slot.className = 'inv-slot';
      if (item) {
        if (item.equipped) slot.classList.add('equipped');
        const rarityClass = item.rarity ? `rarity-${item.rarity}` : '';
        slot.innerHTML = `<span class="${rarityClass}">${item.icon || '?'}</span>${item.count > 1 ? `<span class="item-count">${item.count}</span>` : ''}`;
        slot.onclick = () => showItemDetail(item);
        slot.onmouseenter = (e) => showItemTooltip(e, item);
        slot.onmouseleave = hideItemTooltip;
      }
      grid.appendChild(slot);
    }
  }

  function showItemDetail(item) {
    const panel = document.getElementById('itemDetailPanel');
    const rarityColors = { common: 'var(--rarity-common)', uncommon: 'var(--rarity-uncommon)', rare: 'var(--rarity-rare)', epic: 'var(--rarity-epic)', legendary: 'var(--rarity-legendary)' };
    const color = rarityColors[item.rarity] || 'var(--bone)';

    let actions = '';
    if (item.type === 'weapon') actions += `<button class="btn" onclick="Game.equipItem('${item.id}')">Equip</button>`;
    if (item.type === 'armor') actions += `<button class="btn" onclick="Game.equipItem('${item.id}')">Equip</button>`;
    if (item.type === 'accessory') actions += `<button class="btn" onclick="Game.equipItem('${item.id}')">Equip</button>`;
    if (item.type === 'consumable') actions += `<button class="btn btn-primary" onclick="Game.useItem('${item.id}')">Use</button>`;
    actions += `<button class="btn btn-secondary" onclick="Game.discardItem('${item.id}')">Discard</button>`;

    let stats = '';
    if (item.stats) {
      Object.keys(item.stats).forEach(s => {
        const labels = { atk: 'Attack', def: 'Defense', syn: 'Synchronicity', hp: 'HP Bonus', mp: 'MP Bonus' };
        stats += `<div class="item-stat">${labels[s] || s}: +${item.stats[s]}</div>`;
      });
    }

    panel.innerHTML = `
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
        <span style="font-size:2rem">${item.icon}</span>
        <div>
          <div style="font-family:'Cinzel',serif;color:${color};font-size:1rem">${item.name}</div>
          <div style="font-size:0.6rem;color:rgba(232,224,213,0.5);text-transform:uppercase">${item.type} &bull; ${item.rarity}</div>
        </div>
      </div>
      <div style="font-size:0.75rem;color:rgba(232,224,213,0.7);margin-bottom:0.5rem">${item.desc}</div>
      ${stats ? `<div style="margin-bottom:1rem">${stats}</div>` : ''}
      <div style="display:flex;gap:0.5rem">${actions}</div>
    `;
    panel.classList.add('active');
  }

  function showItemTooltip(e, item) {
    let tooltip = document.getElementById('itemTooltip');
    if (!tooltip) {
      tooltip = document.createElement('div');
      tooltip.id = 'itemTooltip';
      tooltip.className = 'item-tooltip';
      document.body.appendChild(tooltip);
    }
    tooltip.innerHTML = `
      <div class="item-name item-rarity-${item.rarity}">${item.name}</div>
      <div class="item-type">${item.type} &bull; ${item.rarity}</div>
      <div class="item-desc">${item.desc}</div>
    `;
    tooltip.style.left = e.clientX + 15 + 'px';
    tooltip.style.top = e.clientY + 15 + 'px';
    tooltip.classList.add('visible');
  }

  function hideItemTooltip() {
    const tooltip = document.getElementById('itemTooltip');
    if (tooltip) tooltip.classList.remove('visible');
  }

  function equipItem(itemId) {
    const item = state.inventory.find(i => i.id === itemId);
    if (!item) return;
    if (item.type === 'weapon') state.equipped.weapon = item;
    if (item.type === 'armor') state.equipped.armor = item;
    if (item.type === 'accessory') state.equipped.accessory = item;
    state.inventory.forEach(i => { if (i.type === item.type) i.equipped = false; });
    item.equipped = true;
    showNotification('Equipped', `${item.name} equipped.`);
    renderInventory();
  }

  function useItem(itemId) {
    const idx = state.inventory.findIndex(i => i.id === itemId);
    if (idx === -1) return;
    const item = state.inventory[idx];
    if (!item.effect) return;

    if (item.effect.hp) {
      healParty(item.effect.hp);
      showNotification('Used', `${item.name} restored ${item.effect.hp} HP.`);
    }
    if (item.effect.mp) {
      showNotification('Used', `${item.name} restored ${item.effect.mp} MP.`);
    }

    item.count = (item.count || 1) - 1;
    if (item.count <= 0) state.inventory.splice(idx, 1);
    renderInventory();
  }

  function discardItem(itemId) {
    const idx = state.inventory.findIndex(i => i.id === itemId);
    if (idx > -1) {
      state.inventory.splice(idx, 1);
      renderInventory();
      document.getElementById('itemDetailPanel').classList.remove('active');
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // SETTINGS & SAVE/LOAD SYSTEM
  // ═══════════════════════════════════════════════════════════════
  function toggleSetting(key) {
    state.settings[key] = !state.settings[key];
    const toggle = document.getElementById(key + 'Toggle');
    if (toggle) toggle.classList.toggle('active', state.settings[key]);
    if (key === 'music' || key === 'sfx') {
      showNotification('Setting', `${key.toUpperCase()} ${state.settings[key] ? 'enabled' : 'disabled'}.`);
    }
  }

  function updateTextSpeed(val) {
    state.settings.textSpeed = parseInt(val);
    state.settings.textSpeed = Math.max(10, 110 - state.settings.textSpeed);
  }

  function renderSaveSlots() {
    const container = document.getElementById('saveSlots');
    container.innerHTML = '';
    for (let i = 1; i <= 3; i++) {
      const saveData = localStorage.getItem('cos_save_' + i);
      let slot;
      if (saveData) {
        try {
          const parsed = JSON.parse(saveData);
          const date = new Date(parsed.timestamp || Date.now());
          slot = document.createElement('div');
          slot.className = 'save-slot';
          slot.innerHTML = `
            <div class="save-info">
              <div class="save-name">Slot ${i}: ${parsed.name || 'Unknown'}</div>
              <div class="save-date">${date.toLocaleString()} &bull; Ch.${parsed.chapter || 1} &bull; Lv.${parsed.level || 1}</div>
            </div>
            <div class="save-actions">
              <button class="save-btn save-overwrite" onclick="Game.saveToSlot(${i})">Overwrite</button>
              <button class="save-btn" onclick="Game.loadFromSlot(${i})">Load</button>
              <button class="save-btn" onclick="Game.deleteSave(${i})">Delete</button>
            </div>
          `;
        } catch(e) {
          slot = createEmptySlot(i);
        }
      } else {
        slot = createEmptySlot(i);
      }
      container.appendChild(slot);
    }
  }

  function createEmptySlot(i) {
    const div = document.createElement('div');
    div.className = 'save-slot empty';
    div.innerHTML = `
      <div class="save-info">
        <div class="save-name">Slot ${i}: Empty</div>
        <div class="save-date">No save data</div>
      </div>
      <div class="save-actions">
        <button class="save-btn" onclick="Game.saveToSlot(${i})">Save</button>
      </div>
    `;
    return div;
  }

  function saveToSlot(slotNum) {
    const saveData = {
      timestamp: Date.now(),
      name: state.name,
      archetype: state.archetype,
      chapter: state.chapter,
      chapterTitle: state.chapterTitle,
      level: state.level,
      xp: state.xp,
      skillPoints: state.skillPoints,
      corruption: state.corruption,
      honor: state.honor,
      unity: state.unity,
      stats: state.stats,
      social: state.social,
      skills: state.skills,
      inventory: state.inventory,
      equipped: state.equipped,
      settings: state.settings,
      flags: state.flags,
      credits: state.credits,
      essence: state.essence,
      contracts: state.contracts,
      roomsVisited: state.roomsVisited,
      currentRoom: state.currentRoom,
      endingsSeen: state.endingsSeen
    };
    try {
      localStorage.setItem('cos_save_' + slotNum, JSON.stringify(saveData));
      showNotification('Saved', `Game saved to Slot ${slotNum}.`);
      renderSaveSlots();
    } catch(e) {
      showNotification('Error', 'Failed to save game.');
    }
  }

  function loadFromSlot(slotNum) {
    const saveData = localStorage.getItem('cos_save_' + slotNum);
    if (!saveData) {
      showNotification('Empty', 'No save data in Slot ' + slotNum);
      return;
    }
    try {
      const parsed = JSON.parse(saveData);
      // Restore state
      Object.keys(parsed).forEach(key => {
        if (state[key] !== undefined) state[key] = parsed[key];
      });
      // Restore UI
      document.getElementById('partyName1').textContent = state.name;
      // Restore archetype sprites if archetype exists
      if (state.archetype && SPRITES[state.archetype]) {
        document.getElementById('protagonist-avatar').src = SPRITES[state.archetype].front;
        document.getElementById('playerCombatImg').src = SPRITES[state.archetype].front;
        state.echoTransformSprite = ARCHETYPE_ECHO[state.archetype] || 'sprites/echo_protagonist.png';
      }
      updateHPDisplay();
      updateCorruptionDisplay();
      updateSocialDisplay();
      updateResources();
      setRoom(state.currentRoom);
      showNotification('Loaded', `Welcome back, ${state.name}.`);
      returnToGame();
    } catch(e) {
      showNotification('Error', 'Failed to load save data.');
    }
  }

  function deleteSave(slotNum) {
    localStorage.removeItem('cos_save_' + slotNum);
    showNotification('Deleted', `Slot ${slotNum} cleared.`);
    renderSaveSlots();
  }

  function loadGamePrompt() {
    renderSaveSlots();
    // Show a quick-load modal
    let hasSave = false;
    for (let i = 1; i <= 3; i++) {
      if (localStorage.getItem('cos_save_' + i)) { hasSave = true; break; }
    }
    if (!hasSave) {
      showNotification('No Saves', 'No save data found.');
      return;
    }
    toSettings();
  }

  function autoSave() {
    try {
      const saveData = {
        timestamp: Date.now(),
        name: state.name,
        archetype: state.archetype,
        chapter: state.chapter,
        level: state.level,
        corruption: state.corruption,
        honor: state.honor,
        unity: state.unity,
        stats: state.stats,
        social: state.social,
        skills: state.skills,
        inventory: state.inventory,
        equipped: state.equipped,
        settings: state.settings,
        flags: state.flags,
        credits: state.credits,
        essence: state.essence,
        contracts: state.contracts,
        roomsVisited: state.roomsVisited,
        currentRoom: state.currentRoom,
        endingsSeen: state.endingsSeen
      };
      localStorage.setItem('cos_autosave', JSON.stringify(saveData));
    } catch(e) { /* Silently fail */ }
  }

  function exportSave() {
    const saveData = {
      timestamp: Date.now(),
      name: state.name,
      archetype: state.archetype,
      chapter: state.chapter,
      level: state.level,
      corruption: state.corruption,
      honor: state.honor,
      unity: state.unity,
      stats: state.stats,
      social: state.social,
      skills: state.skills,
      inventory: state.inventory,
      equipped: state.equipped,
      settings: state.settings,
      flags: state.flags,
      credits: state.credits,
      essence: state.essence,
      contracts: state.contracts,
      roomsVisited: state.roomsVisited,
      currentRoom: state.currentRoom,
      endingsSeen: state.endingsSeen
    };
    const b64 = btoa(JSON.stringify(saveData));
    navigator.clipboard.writeText(b64).then(() => {
      showNotification('Exported', 'Save data copied to clipboard!');
    }).catch(() => {
      showNotification('Export', b64.substring(0, 50) + '...');
    });
  }

  function importSavePrompt() {
    const data = prompt('Paste your save data:');
    if (!data) return;
    try {
      const parsed = JSON.parse(atob(data));
      Object.keys(parsed).forEach(key => {
        if (state[key] !== undefined) state[key] = parsed[key];
      });
      updateHPDisplay();
      updateCorruptionDisplay();
      updateSocialDisplay();
      updateResources();
      showNotification('Imported', 'Save data loaded successfully!');
      returnToGame();
    } catch(e) {
      showNotification('Error', 'Invalid save data.');
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // ECHO TRANSFORMATION
  // ═══════════════════════════════════════════════════════════════
  function toggleEcho() {
    if (!state.echo) return;
    state.echoActive = !state.echoActive;
    const btn = document.getElementById('echoBtn');
    btn.classList.toggle('active', state.echoActive);

    if (state.echoActive) {
      showNotification('ECHO TRANSFORMATION', `${ECHOES[state.echo]?.name || 'The Echo'} emerges. Power floods your veins. Corruption +10.`);
      modStat('corruption', 10);
      document.getElementById('protagonist-avatar').style.boxShadow = '0 0 15px var(--crimson)';

      // Use archetype-specific echo sprite
      const echoSprite = (state.archetype && ARCHETYPE_ECHO[state.archetype])
        ? ARCHETYPE_ECHO[state.archetype]
        : (ECHO_IMAGES[state.echo] || 'sprites/echo_protagonist.png');

      // Update combat sprite to echo form
      const combatImg = document.getElementById('playerCombatImg');
      if (combatImg) {
        combatImg.src = echoSprite;
        combatImg.style.filter = 'drop-shadow(0 0 20px var(--crimson))';
      }

      // Show echo transform overlay in room
      const roomContent = document.getElementById('roomContent');
      let echoImg = document.getElementById('echoTransformDisplay');
      if (!echoImg) {
        echoImg = document.createElement('img');
        echoImg.id = 'echoTransformDisplay';
        echoImg.className = 'echo-transform-img sprite-echo';
        echoImg.style.cssText = 'position:absolute;right:1rem;top:1rem;z-index:10;margin:0;height:200px;';
        roomContent.appendChild(echoImg);
      }
      echoImg.src = echoSprite;
      echoImg.style.display = '';
    } else {
      showNotification('Reality Anchor', 'You return to physical form. The mask holds... for now.');
      document.getElementById('protagonist-avatar').style.boxShadow = '';

      // Revert combat sprite to normal form
      const combatImg = document.getElementById('playerCombatImg');
      if (combatImg && state.archetype && SPRITES[state.archetype]) {
        combatImg.src = SPRITES[state.archetype].front;
        combatImg.style.filter = 'drop-shadow(0 0 15px var(--accent-color, var(--gold)))';
      }

      const echoImg = document.getElementById('echoTransformDisplay');
      if (echoImg) echoImg.style.display = 'none';
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // ENDING SYSTEM — 6 Endings based on moral axes
  // ═══════════════════════════════════════════════════════════════
  function checkEnding() {
    // Triggered after final boss
    const endings = {
      redeemed: {
        title: 'The Redeemed City',
        condition: () => state.honor > state.corruption && state.honor > state.unity,
        text: `You destroy the Iron Covenant and survive. Vex dies seeing his vision fail. The factions, united by your example, form a council. Neo-Vespera enters a fragile peace. Your mask is fully cracked &mdash; everyone can see your face. Some call you hero. Others call you destroyer. You walk the streets without a mask, for the first time, just a person.`,
        fates: [
          'Silas: Opens an orphanage. Still gambles. Still cheats. But the kids love him.',
          'Magdalene: Becomes the city\'s first elected marshal. Still doesn\'t sleep well.',
          'Orin: Disappears into the Echo. Sometimes people see a violet light in the ruins.',
          'Vex: Dead. His armor is melted down into bells for the new cathedral.'
        ],
        finalText: '"The city doesn\'t need a savior. It needs someone willing to be human. You chose that. It was enough."'
      },
      god: {
        title: 'The God of Chains',
        condition: () => state.corruption > state.honor && state.corruption > state.unity,
        text: `You merge with the Iron Covenant engine. You become something more than human &mdash; a consciousness spanning Neo-Vespera's entire network. Every camera, every microphone, every neon sign becomes your eye. Order is absolute. Crime is impossible. Dissent is detected before it forms. The city prospers. Poverty ends. Hunger ends. Fear... changes. People don\'t fear each other. They fear you.`,
        fates: [
          'Silas: Becomes your voice on the streets. He tells jokes that make people forget they\'re watched.',
          'Magdalene: Leads your enforcers. She writes a code of conduct. You let her. It amuses you.',
          'Orin: Your bridge to the Echo. Together, you\'ve made a realm where the dead never truly leave.',
          'Vex: His consciousness is part of yours now. You argue constantly. It\'s the only conversation that challenges you.'
        ],
        finalText: '"They prayed for a god who would save them. You answered. Salvation has a face now. It is yours. Forever."'
      },
      covenant: {
        title: 'The Covenant of Equals',
        condition: () => state.unity > state.honor && state.unity > state.corruption,
        text: `You realize the Iron Covenant cannot be destroyed &mdash; only shared. You distribute its power equally among all citizens. Everyone gets a voice in the city's consciousness. Everyone shares the burden. It\'s chaos at first. Then compromise. Then something new. Neo-Vespera becomes the first true democracy of the post-Collapse age &mdash; messy, loud, imperfect, and alive.`,
        fates: [
          'Silas: Elected to the council. His speeches are... surprisingly good.',
          'Magdalene: Commands the city guard. Her oath is to the people, not to power.',
          'Orin: Teaches Echo-communication. A new generation learns to speak with the other side.',
          'Vex: Alive. In prison. He writes. His books become required reading in schools. He hates that.'
        ],
        finalText: '"Power concentrated is power corrupted. Power shared is power transformed. The city belongs to everyone now. Including you."'
      },
      sacrifice: {
        title: 'The Sacrifice',
        condition: () => state.social.silas.trust >= 75 && state.social.magdalene.trust >= 75,
        text: `You realize the only way to save everyone &mdash; the city, the Echo, your companions, even Vex &mdash; is to become the conduit yourself. You absorb the Iron Covenant's energy and redirect it into the sky, away from the city. The blast is visible from the Undercroft. When the light fades, you\'re gone. Neo-Vespera is free. The Echo is stable. The factions make peace, because they all tell the story of the person who gave everything.`,
        fates: [
          'Silas: Visits the memorial every week. Leaves cards. Never plays them.',
          'Magdalene: Keeps the memorial clean. Her armor is silent now.',
          'Orin: Says he can still hear you, sometimes, in the static between stations.',
          'Vex: Writes your story. It\'s the most honest thing he\'s ever done.'
        ],
        finalText: '"Every debt must be paid. You paid yours in full. The city remembers."'
      },
      newconcordat: {
        title: 'The New Concordat',
        condition: () => state.social.vex.trust >= 30,
        text: `You and Vex realize you've been fighting the same war from different sides. Together, you dismantle the Iron Covenant and rebuild the Concordat from within. It\'s still authoritarian &mdash; but now it\'s fair. Debts are financial again. The Echo is regulated, not exploited. It\'s not freedom. It\'s not utopia. But it\'s order with compassion.`,
        fates: [
          'Silas: Finds legitimate work. Hates it. Does it anyway.',
          'Magdalene: Leads the reformed guard. Compassion is now part of the oath.',
          'Orin: Negotiates the Echo Treaty. The first legal framework for the other side.',
          'Vex: Your partner. Your shadow. Your constant reminder of what you could become.'
        ],
        finalText: '"You didn\'t destroy the system. You changed it. History will argue whether that was enough. You know it had to be."'
      },
      defaultEnding: {
        title: 'The Penitent\'s Path',
        condition: () => true,
        text: `The Iron Covenant is destroyed. The Echo recedes. Neo-Vespera, scarred but alive, begins to heal. You walk away from the ruins, mask in hand, not sure where you're going. But for the first time, the direction is yours to choose.`,
        fates: [
          'Silas: Disappears into the crowd. You know he\'ll be fine.',
          'Magdalene: Finds peace in protecting those who remain.',
          'Orin: Returns to the Echo. He\'ll watch over both worlds.',
          'Vex: His story ends with the machine he built.'
        ],
        finalText: '"The city endures. So do you. That is enough."'
      }
    };

    // Find matching ending
    let ending = endings.redeemed;
    if (endings.sacrifice.condition()) ending = endings.sacrifice;
    else if (endings.newconcordat.condition()) ending = endings.newconcordat;
    else if (endings.redeemed.condition()) ending = endings.redeemed;
    else if (endings.god.condition()) ending = endings.god;
    else if (endings.covenant.condition()) ending = endings.covenant;
    else ending = endings.defaultEnding;

    state.endingsSeen.push(ending.title);
    autoSave();

    // Show ending screen
    document.querySelectorAll('.scene').forEach(s => {
      s.classList.remove('active');
      s.style.display = 'none';
    });
    const endingScene = document.getElementById('scene-ending');
    endingScene.style.display = '';
    endingScene.classList.add('active');

    document.getElementById('endingTitle').textContent = ending.title;
    document.getElementById('endingContent').innerHTML = `
      <p>${ending.text}</p>
      <div style="margin:1.5rem 0;padding:1rem;background:rgba(0,0,0,0.3);border-radius:4px;">
        <h3 style="font-family:'Cinzel',serif;color:var(--gold);margin-bottom:0.5rem">Companions' Fates</h3>
        ${ending.fates.map(f => `<p style="margin:0.3rem 0;font-size:0.8rem">${f}</p>`).join('')}
      </div>
      <p style="font-style:italic;color:rgba(232,224,213,0.6);margin-top:1rem">${ending.finalText}</p>
    `;
  }

  // ═══════════════════════════════════════════════════════════════
  // ADDITIONAL DIALOGUE ENTRIES
  // ═══════════════════════════════════════════════════════════════
  DIALOGUES.combat_ambush = {
    speaker: 'System', speakerId: 'gargoyle',
    text: 'From the shadows, a biomechanical horror lunges! Its fiber-optic eyes blaze crimson as it locks onto your heat signature. UNAUTHORIZED PRESENCE DETECTED. INITIATING REDEMPTION PROTOCOL.',
    choices: [
      { text: '[Penitent Stance] Defend the party.', tag: 'redemption', tagText: 'Defend', effect: () => { setStance('penitent'); enterCombat(); } },
      { text: '[Inquisitor Stance] Strike first!', tag: 'betrayal', tagText: 'Attack', effect: () => { setStance('inquisitor'); enterCombat(); } },
      { text: '[Heretic Stance] Unleash Echo magic.', tag: 'echo', tagText: 'Heretic', effect: () => { setStance('heretic'); modStat('corruption',5); enterCombat(); } }
    ]
  };

  DIALOGUES.vex_phase3 = {
    speaker: 'Cardinal Vex', speakerId: 'vex',
    text: 'The engine... it\'s consuming me. I can feel my thoughts becoming... protocol. Penitent. You have one final choice. Destroy the engine and kill all Echo-touched beings. Seize control and become the new ruler. Or merge with the Echo and transcend.',
    choices: [
      { text: 'Destroy the engine. End the threat.', tag: 'redemption', tagText: 'Destroy', effect: () => { modAxis('honor',20); checkEnding(); } },
      { text: 'Seize control. Rule Neo-Vespera.', tag: 'betrayal', tagText: 'Rule', effect: () => { modStat('corruption',30); modAxis('honor',-20); checkEnding(); } },
      { text: 'Merge with the Echo. Become more.', tag: 'echo', tagText: 'Transcend', effect: () => { modStat('corruption',50); checkEnding(); } },
      { text: '[Requires: All companions trust 75+] Sacrifice yourself.', tag: 'covenant', tagText: 'Sacrifice',
        effect: () => { if (state.social.silas.trust >= 75 && state.social.magdalene.trust >= 75) checkEnding(); else { showNotification('Locked','Not enough trust.'); loadDialogue('vex_phase3'); } } }
    ]
  };

  DIALOGUES.warden_aftermath = {
    speaker: 'The Warden', speakerId: 'warden',
    text: '*coughing blood* I was... I was trying to protect them. The Echo takes everything. The machine was the only way to... to filter it. Please. Understand.',
    choices: [
      { text: 'Execute the Warden. Justice demands it.', tag: 'betrayal', tagText: 'Execute', effect: () => { modTrust('magdalene',20); modAxis('honor',-5); showNotification('Executed','Magdalene nods silently.'); } },
      { text: 'Spare him. We need informants, not corpses.', tag: 'redemption', tagText: 'Spare', effect: () => { modAxis('unity',10); showNotification('Spared','The Warden becomes your informant.'); } }
    ]
  };

  // ═══════════════════════════════════════════════════════════════
  // PUBLIC API
  // ═══════════════════════════════════════════════════════════════
  return {
    // Core
    init, showScene, returnToGame, returnToTitle, resetToTitle,
    // Navigation
    toCreation, toSettings, toSocial, toSkillTree, toInventory,
    openMenu, showCredits, loadGamePrompt,
    // Character Creation
    selectAsset, selectColor, setRotation, selectArchetype, selectOrigin, selectEcho,
    updateName, adjustStat, randomizeChar, startGame,
    // Gameplay
    exploreRoom, enterCombat, talkToNPC, moveRoom,
    selectPartyMember,
    // Combat
    combatAttack, combatSkill, combatDefend, combatFlee,
    setStance, toggleItemPanel,
    // Echo
    toggleEcho,
    // Systems
    unlockSkill, switchSkillBranch,
    equipItem, useItem, discardItem, switchInvTab,
    toggleSetting, updateTextSpeed,
    saveToSlot, loadFromSlot, deleteSave,
    exportSave, importSavePrompt,
    // Utility
    showNotification: showNotification
  };
})();

// ═══════════════════════════════════════════════════════════════
// DOM EVENT LISTENERS
// ═══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  Game.init();
});
</script>
</body>
</html>
